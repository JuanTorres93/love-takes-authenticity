    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
