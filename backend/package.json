{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "npm run test -- --watch",
    "dev": "NODE_ENV=development nodemon --exec tsx src/infra/server.ts",
    "start:test-server": "NODE_ENV=test PORT=4444 nodemon --exec tsx src/infra/server.ts",
    "stop:test-server": "kill $(lsof -t -i:4444) 2>/dev/null || true",
    "build": "esbuild src/infra/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js",
    "start": "NODE_ENV=production node dist/server.js"
  },
  "keywords": [],
  "author": "",
